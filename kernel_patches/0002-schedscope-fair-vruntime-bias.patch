+#define SCHEDSCOPE_VRUNTIME_PLACEMENT_BIAS 1
+#define SCHEDSCOPE_VRUNTIME_BIAS_STEP_NS 50000LL
+
+static inline s64 schedscope_vruntime_placement_bias(struct sched_entity *se)
+{
+	struct task_struct *p;
+	int nice;
+
+	if (!SCHEDSCOPE_VRUNTIME_PLACEMENT_BIAS || !entity_is_task(se))
+		return 0;
+
+	p = task_of(se);
+	nice = task_nice(p);
+
+	/*
+	 * Apply a small bounded placement bias so lower nice values
+	 * re-enter slightly earlier and higher nice values slightly later.
+	 */
+	return (s64)nice * SCHEDSCOPE_VRUNTIME_BIAS_STEP_NS;
+}
